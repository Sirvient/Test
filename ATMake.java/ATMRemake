import java.util.Scanner;

public class ATMRemake {

    static Scanner input = new Scanner(System.in);
    static int correctPin = 123;
    static int userPin;
    static int attempts = 0;
    static int transactionMenu;
    static char transactionChoice;
    static int balance = 50000;
    static int amount;
        static char checkbalancecharge;
            static char withdrawCashCharge;
                
                    public static void main(String[] args) {

        do {
            inputPin();
            if (userPin == correctPin){
                do {
                    transactionMenu();
                    switch (transactionMenu) {
                        case 1:
                            checkBalance();
                            anotherTransaction();
                            break;
                        case 2:
                            withdrawCashCharge();
                            anotherTransaction();
                            break;
                        case 3:
                            endOfTransaction();
                        default:
                            System.out.println("Invalid choice.");
                    }
                } while (transactionChoice == 'Y' || transactionChoice == 'y');
            } else if (attempts < 3){
                attemptsRemaining();
            } else {
                System.out.println("Invalid.");
            }
        } while (attempts < 3);

    }

